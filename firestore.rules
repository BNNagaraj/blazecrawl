rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // API keys: users can only read/manage their own keys
    match /apiKeys/{keyId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      // No delete — keys are deactivated, not removed
      allow delete: if false;
    }

    // User profiles: users can only access their own
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Crawl jobs: users can only read their own jobs (server creates them)
    match /crawlJobs/{jobId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Only server (admin SDK) can create/update crawl jobs
      allow create, update, delete: if false;
    }

    // Activity logs: read-only for the owning user
    match /activity/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
